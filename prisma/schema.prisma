generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  apiRequests ApiRequestLog[]
}

model ApiRequestLog {
  id           String   @id @default(cuid())
  userId       String?
  requestIp    String?
  path         String
  method       String
  statusCode   Int?
  tokensUsed   Int?
  createdAt    DateTime @default(now())

  user         User?    @relation(fields: [userId], references: [id])
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

